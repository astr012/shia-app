# ============================================================
# SignAI_OS — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# Backend
ENV=development
HOST=0.0.0.0
PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# OpenAI (optional — system works without it using rule-based fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ElevenLabs Premium TTS (optional)
# ELEVENLABS_API_KEY=

# Database (future)
# DATABASE_URL=postgresql://user:pass@localhost:5432/signai
# SUPABASE_URL=
# SUPABASE_KEY=

# Auth (future)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
