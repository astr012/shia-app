# ============================================================
# SignAI_OS — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# ── Server ───────────────────────────────────────────────────
ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── Frontend (CORS) ─────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── OpenAI (optional — system works without it using rule-based fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Rate Limiting ────────────────────────────────────────────
WS_RATE_LIMIT=20
REST_RATE_LIMIT=60

# ── ElevenLabs Premium TTS (optional) ───────────────────────
# ELEVENLABS_API_KEY=

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET_KEY=generate_a_strong_random_secret_here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# ── Redis (optional — falls back to in-memory) ──────────────
# REDIS_URL=redis://localhost:6379/0

# ── Database ────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/signai
