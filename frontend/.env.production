# ============================================================
# SignAI_OS — Production Environment (Vercel)
# Non-secret, NEXT_PUBLIC_ client-side variables only.
# These are safe to commit — they are publicly embedded in
# the JS bundle at build time by Next.js.
# ============================================================

# REST API (Render backend)
NEXT_PUBLIC_API_URL=https://shignai-backend.onrender.com

# WebSocket (Render backend)
NEXT_PUBLIC_WS_URL=wss://shignai-backend.onrender.com/ws

# Phase 5 WebRTC NAT Traversal (Optional TURN relay)
NEXT_PUBLIC_TURN_URL=turn:global.turn.twilio.com:3478
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_PASSWORD=
